# Advanced/operator-override template
# This file contains compatibility, TLS, integration, and internal override
# knobs that are intentionally excluded from the normal `.env.example`.

APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://localhost
ASSET_URL=/
APP_SSL_PORT=443
APP_PORT=80
SSL_MODE=self-signed
SSL_CERT_DOMAIN=localhost
# Optional comma-separated extra DNS names for CA-managed issuance.
SSL_CERT_ALT_NAMES=jobboard.local
# Optional comma-separated extra DNS/IP SANs used only for self-signed certificates.
SSL_SELF_SIGNED_ALT_NAMES=jobboard.local,127.0.0.1
# cloudflare-origin mode: operator-provided source files copied into runtime nginx ssl path
SSL_CLOUDFLARE_ORIGIN_CERT_FILE=
SSL_CLOUDFLARE_ORIGIN_KEY_FILE=
# letsencrypt mode: acme.sh is the default client; certbot is supported as a fallback
SSL_ACME_CLIENT=acme.sh
SSL_ACME_EMAIL=
SSL_ACME_CA=letsencrypt
SSL_ACME_FORCE_RENEW=false
SSL_LETSENCRYPT_CHALLENGE=dns-cloudflare
SSL_CERTBOT_CREDENTIALS_FILE=
# Cloudflare DNS-01 inputs for letsencrypt mode
CF_Token=
CF_Zone_ID=
WWWUSER=1000
WWWGROUP=1000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# HTTP Response Logging
HTTP_LOGGING_ENABLED=true
HTTP_LOGGING_SUCCESS=true
HTTP_LOGGING_REDIRECTS=true
HTTP_LOGGING_SLOW_THRESHOLD=1000

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=laravel
DB_USERNAME=postgres
DB_PASSWORD=
# For local dev outside Docker, change DB_HOST to 127.0.0.1

# Installation bootstrap guard
# Local/testing defaults can leave the installer open; production-like environments should set one or more of:
# INSTALL_GUARD_ENABLED=true
# INSTALL_ALLOWED_IPS=127.0.0.1,203.0.113.10
# INSTALL_TOKEN=change-me

# Reverse proxy trust
# Trust only your direct front proxy by default.
TRUSTED_PROXIES=REMOTE_ADDR
# Supported values: x_forwarded, forwarded, aws_elb, traefik
TRUSTED_PROXY_HEADERS=x_forwarded

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@localhost"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
VITE_PORT=5173
# Set to your dev hostname when using a custom domain (e.g. OrbStack)
# VITE_HMR_HOST=laravel.test.jobs-boards.orb.local

# Host-forwarded service ports (exposed on 127.0.0.1 for local tooling)
FORWARD_DB_PORT=5432
FORWARD_REDIS_PORT=6379

# enable web ui for CrowdSec console and API
CROWDSEC_ENROLL_KEY=
CROWDSEC_DISABLE_ONLINE_API=true
CROWDSEC_DNS_PRIMARY=1.1.1.1
CROWDSEC_DNS_SECONDARY=8.8.8.8

# Monitoring ingress policy
# internal-only: allow only MONITORING_ALLOWED_CIDRS and keep auth on protected routes
# auth-only: no CIDR gate, auth still protects Grafana and Prometheus
# disabled: monitoring routes return 404
MONITORING_ACCESS_MODE=internal-only
MONITORING_ALLOWED_CIDRS=127.0.0.1/32,172.29.0.0/24
BT_STATE_DIR=.blue-team-vm
BT_HONEYPOT_SOURCE=./docker/nginx/includes/blue-team-honeypot.conf
# Leave blank to let bootstrap-env.sh persist the detected or default shared app-plane network name.
BT_APP_PLANE_NETWORK_NAME=
# canonical operator-facing monitoring inputs
MONITORING_ADMIN_USERNAME=
MONITORING_PASSWORD=
# derived/runtime bcrypt hash for auth-service monitoring login
MONITORING_PASSWORD_HASH=
# shared session HMAC secret for auth-service
SESSION_SECRET=
# client-side (Vite) variables are generated by bootstrap-env.sh in
# docker/auth-service/frontend/.env and prefixed with VITE_.
# they control the login page behaviour (auth endpoints, default redirect)
# advanced override: plaintext source for Grafana admin bootstrap; defaults to MONITORING_PASSWORD when unset
GRAFANA_PASSWORD=
# resolver-consumer runtime path override; defaults to ${BT_STATE_DIR}/rendered/grafana.datasources.yml when unset
GRAFANA_DATASOURCES_FILE=
# derived/runtime file path for Grafana admin bootstrap
GRAFANA_ADMIN_SECRET_FILE=
# advanced override: plaintext source for Prometheus basic auth bootstrap; defaults to MONITORING_PASSWORD when unset
PROMETHEUS_PASSWORD=
# final derived/runtime bcrypt hash for Prometheus basic auth
PROMETHEUS_PASSWORD_HASH=
# resolver-consumer runtime path override; defaults to ${BT_STATE_DIR}/rendered/prometheus.web-config.yml when unset
PROMETHEUS_WEB_CONFIG_FILE=

# ── Auth Service (docker/auth-service) ──
# Shared HMAC secret used by auth-service when mirroring canonical audit events
CANONICAL_AUDIT_AUTH_SERVICE_SECRET=

# Port to run the auth service on (optional)
PORT=3000
