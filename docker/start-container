#!/usr/bin/env bash
set -euo pipefail

PHP_BIN=${PHP_BIN:-$(command -v php || true)}
if [ -z "$PHP_BIN" ] || [ ! -x "$PHP_BIN" ]; then
    echo "Error: PHP binary not found. Set PHP_BIN to a valid php executable." >&2
    exit 1
fi
export PHP_BIN

/usr/local/bin/prepare-laravel-runtime /var/www/html

mkdir -p /var/log/laravel
ln -sf /var/www/html/storage/logs/laravel.log /var/log/laravel/laravel.log 2>/dev/null || true

$PHP_BIN /var/www/html/artisan migrate --force 2>&1 || true

exec /usr/bin/supervisord -n -c /etc/supervisor/conf.d/supervisord.conf
