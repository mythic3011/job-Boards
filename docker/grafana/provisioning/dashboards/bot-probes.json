{
  "title": "Bot Probes",
  "uid": "bot-probes",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "1m",
  "time": { "from": "now-24h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Bot probes over time",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 8 },
      "datasource": { "type": "postgres", "uid": "${DS_JOBSBOARDS-POSTGRES}" },
      "targets": [
        {
          "rawSql": "SELECT\n  $__timeGroupAlias(occurred_at, $__interval),\n  count(*) AS value\nFROM audit_logs\nWHERE\n  event_type = 'bot_fingerprint_probe'\n  AND $__timeFilter(occurred_at)\nGROUP BY 1\nORDER BY 1;",
          "format": "time_series",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Top IPs by probe count",
      "type": "table",
      "gridPos": { "x": 0, "y": 8, "w": 16, "h": 8 },
      "datasource": { "type": "postgres", "uid": "${DS_JOBSBOARDS-POSTGRES}" },
      "targets": [
        {
          "rawSql": "SELECT\n  ip,\n  count(*) AS probes,\n  min(occurred_at) AS first_seen,\n  max(occurred_at) AS last_seen\nFROM audit_logs\nWHERE\n  event_type = 'bot_fingerprint_probe'\n  AND $__timeFilter(occurred_at)\nGROUP BY ip\nORDER BY probes DESC\nLIMIT 50;",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Headless ratio (%)",
      "type": "stat",
      "gridPos": { "x": 16, "y": 8, "w": 8, "h": 8 },
      "datasource": { "type": "postgres", "uid": "${DS_JOBSBOARDS-POSTGRES}" },
      "options": {
        "reduceOptions": { "calcs": ["last"] },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "value",
        "graphMode": "none"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "red", "value": 80 }
            ]
          }
        }
      },
      "targets": [
        {
          "rawSql": "SELECT\n  100.0 * SUM((meta->>'headless')::boolean::int) / NULLIF(COUNT(*), 0) AS headless_ratio\nFROM audit_logs\nWHERE\n  event_type = 'bot_fingerprint_probe'\n  AND $__timeFilter(occurred_at);",
          "format": "table",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "CrowdSec ban decisions (banned-page-probe)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 16, "w": 24, "h": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "crowdsec_decisions{scenario=\"custom/banned-page-probe\"}",
          "legendFormat": "active bans",
          "refId": "A"
        }
      ]
    }
  ],
  "__inputs": [
    {
      "name": "DS_JOBSBOARDS-POSTGRES",
      "label": "JobsBoards-Postgres",
      "type": "datasource",
      "pluginId": "postgres"
    }
  ]
}
