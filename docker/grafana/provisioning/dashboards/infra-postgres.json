{
    "title": "Infra / Postgres",
    "uid": "infra-postgres",
    "schemaVersion": 38,
    "version": 1,
    "refresh": "1m",
    "time": { "from": "now-24h", "to": "now" },
    "panels": [
        {
            "id": 1,
            "title": "Current DB Connections",
            "type": "stat",
            "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
            "datasource": { "type": "postgres", "uid": "P8E949C5F1FC6F134" },
            "targets": [
                {
                    "rawSql": "SELECT NOW() AS \"time\", count(*)::double precision AS value FROM pg_stat_activity;",
                    "format": "time_series",
                    "refId": "A"
                }
            ],
            "options": {
                "reduceOptions": { "calcs": ["lastNotNull"] },
                "colorMode": "value"
            }
        },
        {
            "id": 2,
            "title": "Waiting Connections",
            "type": "stat",
            "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
            "datasource": { "type": "postgres", "uid": "P8E949C5F1FC6F134" },
            "targets": [
                {
                    "rawSql": "SELECT NOW() AS \"time\", count(*)::double precision AS value FROM pg_stat_activity WHERE wait_event IS NOT NULL;",
                    "format": "time_series",
                    "refId": "A"
                }
            ],
            "options": {
                "reduceOptions": { "calcs": ["lastNotNull"] },
                "colorMode": "background"
            }
        },
        {
            "id": 3,
            "title": "Transactions (DB cumulative)",
            "type": "timeseries",
            "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
            "datasource": { "type": "postgres", "uid": "P8E949C5F1FC6F134" },
            "targets": [
                {
                    "rawSql": "SELECT NOW() AS \"time\", SUM(xact_commit)::double precision AS value FROM pg_stat_database;",
                    "format": "time_series",
                    "legendFormat": "commits",
                    "refId": "A"
                },
                {
                    "rawSql": "SELECT NOW() AS \"time\", SUM(xact_rollback)::double precision AS value FROM pg_stat_database;",
                    "format": "time_series",
                    "legendFormat": "rollbacks",
                    "refId": "B"
                }
            ]
        },
        {
            "id": 4,
            "title": "Longest Running Active Queries",
            "type": "table",
            "gridPos": { "x": 0, "y": 4, "w": 12, "h": 10 },
            "datasource": { "type": "postgres", "uid": "P8E949C5F1FC6F134" },
            "targets": [
                {
                    "rawSql": "SELECT pid, usename, state, now() - query_start AS runtime, left(query, 220) AS query FROM pg_stat_activity WHERE state = 'active' AND query NOT ILIKE '%pg_stat_activity%' ORDER BY runtime DESC LIMIT 20;",
                    "format": "table",
                    "refId": "A"
                }
            ]
        },
        {
            "id": 5,
            "title": "DB Size By Database",
            "type": "table",
            "gridPos": { "x": 12, "y": 8, "w": 12, "h": 6 },
            "datasource": { "type": "postgres", "uid": "P8E949C5F1FC6F134" },
            "targets": [
                {
                    "rawSql": "SELECT datname AS database, pg_size_pretty(pg_database_size(datname)) AS size FROM pg_database ORDER BY pg_database_size(datname) DESC;",
                    "format": "table",
                    "refId": "A"
                }
            ]
        }
    ]
}
