{
  "title": "CrowdSec Security Dashboard",
  "uid": "crowdsec-security",
  "version": 1,
  "schemaVersion": 38,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "version": 2,
  "revision": 1,
  "templating": {
    "list": [
      {
        "name": "interval",
        "type": "interval",
        "options": ["1m", "5m", "15m", "1h"],
        "current": { "value": "5m" }
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "name": "CrowdSec Bans",
        "type": "dashboard",
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "expr": "changes(cs_active_decisions{action=\"ban\"}[1m]) > 0",
        "step": "60s",
        "titleFormat": "New Ban",
        "tagKeys": "reason"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Active Bans",
      "type": "stat",
      "gridPos": { "x": 0, "y": 0, "w": 4, "h": 4 },
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(cs_active_decisions{action=\"ban\"}) or vector(0)",
          "legendFormat": "Bans",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Total Alerts",
      "type": "stat",
      "gridPos": { "x": 4, "y": 0, "w": 4, "h": 4 },
      "options": { "colorMode": "background", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(cs_alerts) or vector(0)",
          "legendFormat": "Alerts",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Bouncer Decisions (OK vs KO)",
      "type": "stat",
      "gridPos": { "x": 8, "y": 0, "w": 4, "h": 4 },
      "options": { "colorMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" } } },
      "targets": [
        {
          "expr": "sum(increase(cs_lapi_decisions_ok_total[5m]))",
          "legendFormat": "Allowed",
          "refId": "A"
        },
        {
          "expr": "sum(increase(cs_lapi_decisions_ko_total[5m]))",
          "legendFormat": "Blocked",
          "refId": "B"
        }
      ]
    },
    {
      "id": 4,
      "title": "Active Decisions by Reason",
      "type": "piechart",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 8 },
      "options": { "pieType": "pie", "legend": { "displayMode": "table", "placement": "right" }, "interval": "1m" },
      "targets": [
        {
          "expr": "cs_active_decisions{action=\"ban\"}",
          "legendFormat": "{{reason}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Bouncer Requests / min",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(cs_lapi_bouncer_requests_total[1m])) * 60",
          "legendFormat": "Requests/min",
          "refId": "A"
        },
        {
          "expr": "sum(rate(cs_lapi_decisions_ok_total[1m])) * 60",
          "legendFormat": "Allowed/min",
          "refId": "B"
        },
        {
          "expr": "sum(rate(cs_lapi_decisions_ko_total[1m])) * 60",
          "legendFormat": "Blocked/min",
          "refId": "C"
        }
      ]
    },
    {
      "id": 6,
      "title": "Nginx — HTTP Status Codes / min",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "sum by(status) (rate(nginx_http_requests_total[1m])) * 60",
          "legendFormat": "{{status}}",
          "refId": "A"
        }
      ],
      "options": { "interval": "1m" }
    },
    {
      "id": 7,
      "title": "Nginx — Request Latency P99",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(nginx_http_request_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "P99 latency",
          "refId": "A"
        }
      ],
      "options": { "interval": "1m" }
    },
    {
      "id": 8,
      "title": "Rate Limit Hits (429) / min",
      "type": "stat",
      "gridPos": { "x": 0, "y": 20, "w": 4, "h": 4 },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 20 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(nginx_http_requests_total{status=\"429\"}[1m])) * 60",
          "legendFormat": "429/min",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Bucket Overflows (Detections) / min",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10 },
          "color": { "fixedColor": "red", "mode": "fixed" }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(cs_bucket_overflowed_total[1m])) * 60",
          "legendFormat": "Overflows/min",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "title": "Log Lines Parsed / min",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 10 }
        }
      },
      "targets": [
        {
          "expr": "sum(rate(cs_filesource_hits_total[1m])) * 60",
          "legendFormat": "Lines read/min",
          "refId": "A"
        },
        {
          "expr": "sum(rate(cs_parser_hits_ok_total[1m])) * 60",
          "legendFormat": "Parsed OK/min",
          "refId": "B"
        }
      ]
    },
    {
      "id": 8,
      "title": "Active Bans Over Time",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 20 },
          "color": { "fixedColor": "red", "mode": "fixed" }
        }
      },
      "targets": [
        {
          "expr": "sum(cs_active_decisions{action=\"ban\"}) or vector(0)",
          "legendFormat": "Active Bans",
          "refId": "A"
        }
      ]
    }
  ]
}
