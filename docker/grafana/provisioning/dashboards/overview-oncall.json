        {
            "id": 1,
            "title": "RPS (last 1m)",
            "type": "stat",
            "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
            "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
            "targets": [
                {
                    "expr": "sum(rate(nginx_http_requests_total[1m]))",
                    "refId": "A"
                }
            ],
            "options": {
                "reduceOptions": { "calcs": ["lastNotNull"] },
                "colorMode": "value"
            },
            "links": [
                {
                    "title": "Open HTTP / WAF / Edge",
                    "url": "/d/http-edge/http-waf-edge",
                    "targetBlank": false
                }
            ]
        },
