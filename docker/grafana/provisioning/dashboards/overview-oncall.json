{
    "title": "Overview - Oncall",
    "uid": "overview-oncall",
    "schemaVersion": 38,
    "version": 3,
    "refresh": "30s",
    "time": { "from": "now-6h", "to": "now" },
    "templating": {
        "list": [
            {
                "name": "ban_ip",
                "label": "Banned IP",
                "type": "query",
                "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
                "query": "query_result(topk(30, sum by (ip) (count_over_time({job=\"crowdsec\",source=\"nginx-bouncer\"} |= \"ban\" | regexp \"(?P<ip>(?:\\\\d{1,3}\\\\.){3}\\\\d{1,3})\" [1h]))))",
                "regex": "/ip=\\\"([^\\\"]+)\\\"/",
                "refresh": 2,
                "sort": 3,
                "multi": false,
                "includeAll": false
            }
        ]
    },
    "links": [
        {
            "title": "HTTP / WAF / Edge",
            "type": "dashboards",
            "tags": [],
            "asDropdown": false,
            "icon": "external link",
            "url": "/d/http-edge/http-waf-edge"
        },
        {
            "title": "Laravel Logs",
            "type": "dashboards",
