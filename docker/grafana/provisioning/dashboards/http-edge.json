{
    "title": "HTTP / WAF / Edge",
    "uid": "http-edge",
    "schemaVersion": 38,
    "version": 4,
    "refresh": "30s",
    "time": { "from": "now-6h", "to": "now" },
    "templating": {
        "list": [
            {
                "name": "ban_ip",
                "label": "Banned IP",
                "type": "query",
                "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
                "query": "query_result(topk(30, sum by (ip) (count_over_time({job=\"crowdsec\",source=\"nginx-bouncer\"} |= \"ban\" | regexp \"(?P<ip>(?:\\\\d{1,3}\\\\.){3}\\\\d{1,3})\" [1h]))))",
                "regex": "/ip=\\\"([^\\\"]+)\\\"/",
                "refresh": 2,
                "sort": 3,
                "multi": false,
                "includeAll": false
            }
        ]
    },
    "panels": [
        {
            "id": 1,
            "title": "RPS",
            "type": "stat",
            "gridPos": { "x": 0, "y": 0, "w": 8, "h": 5 },
            "datasource": { "type": "prometheus", "uid": "PBFA97CFB590B2093" },
            "targets": [
                {
                    "expr": "sum(rate(nginx_http_requests_total[1m]))",
                    "refId": "A"
                }
            ],
            "options": {
                "reduceOptions": { "calcs": ["lastNotNull"] },
                "colorMode": "value"
            }
        },
        {
            "id": 2,
            "title": "4xx / min",
            "type": "stat",
            "gridPos": { "x": 8, "y": 0, "w": 8, "h": 5 },
            "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
            "targets": [
                {
                    "expr": "sum(count_over_time({job=\"nginx\"} |~ \" 4[0-9]{2} \" [1m]))",
                    "refId": "A"
                }
            ],
            "options": {
                "reduceOptions": { "calcs": ["lastNotNull"] },
                "colorMode": "background"
            }
        },
        {
            "id": 3,
            "title": "5xx / min",
            "type": "stat",
            "gridPos": { "x": 16, "y": 0, "w": 8, "h": 5 },
            "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
            "targets": [
                {
                    "expr": "sum(count_over_time({job=\"nginx\"} |~ \" 5[0-9]{2} \" [1m]))",
                    "refId": "A"
                }
            ],
            "options": {
                "reduceOptions": { "calcs": ["lastNotNull"] },
                "colorMode": "background"
            }
        },
        {
            "id": 4,
            "title": "CrowdSec Bans Over Time",
            "type": "timeseries",
            "gridPos": { "x": 0, "y": 5, "w": 12, "h": 8 },
            "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
            "targets": [
                {
                    "expr": "count_over_time({job=\"crowdsec\",source=\"engine\"}[5m])",
                    "legendFormat": "engine lines",
                    "refId": "A"
                },
                {
                    "expr": "count_over_time({job=\"crowdsec\",source=\"nginx-bouncer\"} |= \"ban\" [5m])",
                    "legendFormat": "bouncer bans",
                    "refId": "B"
                }
            ]
        },
        {
            "id": 5,
            "title": "Top CrowdSec Scenarios (last 30m)",
            "type": "bargauge",
            "gridPos": { "x": 12, "y": 5, "w": 6, "h": 8 },
            "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
            "targets": [
                {
                    "expr": "topk(10, sum by (scenario) (count_over_time({job=\"crowdsec\",source=\"engine\"} | regexp \"scenario=(?P<scenario>[a-zA-Z0-9_.:/-]+)\" [30m])))",
                    "refId": "A"
                }
            ],
            "options": {
                "displayMode": "gradient",
                "orientation": "horizontal",
                "reduceOptions": { "calcs": ["lastNotNull"] }
            }
        },
        {
            "id": 10,
            "title": "Top Banned IPs (last 1h)",
            "type": "bargauge",
            "gridPos": { "x": 18, "y": 5, "w": 6, "h": 8 },
            "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
            "targets": [
                {
                    "expr": "topk(10, sum by (ip) (count_over_time({job=\"crowdsec\",source=\"nginx-bouncer\"} |= \"ban\" | regexp \"(?P<ip>(?:[0-9]{1,3}\\\\.){3}[0-9]{1,3})\" [1h])))",
                    "refId": "A"
                }
            ],
            "options": {
                "displayMode": "gradient",
                "orientation": "horizontal",
                "reduceOptions": { "calcs": ["lastNotNull"] }
            }
        },
        {
            "id": 6,
            "title": "Last Banned IPs",
            "type": "logs",
            "gridPos": { "x": 0, "y": 13, "w": 12, "h": 10 },
            "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
            "targets": [
                {
                    "expr": "{job=\"crowdsec\",source=\"nginx-bouncer\"} |= \"ban\"",
                    "queryType": "range",
                    "refId": "A"
                }
            ],
            "options": {
                "showTime": true,
                "showLabels": true,
                "sortOrder": "Descending",
                "dedupStrategy": "none",
                "enableLogDetails": true,
                "prettifyLogMessage": true
            }
        },
        {
            "id": 7,
            "title": "Suspicious Requests For Selected Banned IP",
            "type": "logs",
            "gridPos": { "x": 12, "y": 13, "w": 12, "h": 7 },
            "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
            "targets": [
                {
                    "expr": "{job=\"nginx\"} |~ \"$ban_ip\" |~ \" (403|429|444) \"",
                    "queryType": "range",
                    "refId": "A"
                }
            ],
            "options": {
                "showTime": true,
                "showLabels": true,
                "sortOrder": "Descending",
                "dedupStrategy": "none",
                "enableLogDetails": true,
                "prettifyLogMessage": true
            }
        },
        {
            "id": 8,
            "title": "All Requests For Selected Banned IP",
            "type": "logs",
            "gridPos": { "x": 12, "y": 20, "w": 12, "h": 3 },
            "datasource": { "type": "loki", "uid": "P8E80F9AEF21F6940" },
            "targets": [
                {
                    "expr": "{job=\"nginx\"} |~ \"$ban_ip\"",
                    "queryType": "range",
                    "refId": "A"
                }
            ],
            "options": {
                "showTime": true,
                "showLabels": true,
                "sortOrder": "Descending",
                "dedupStrategy": "none",
                "enableLogDetails": true,
                "prettifyLogMessage": true
            }
        },
        {
            "id": 9,
            "title": "Standard Explore Queries",
            "type": "text",
            "gridPos": { "x": 0, "y": 23, "w": 24, "h": 5 },
            "options": {
                "mode": "markdown",
                "content": "Use these as framework baseline in Explore:\n\n- `count_over_time({job=\\\"crowdsec\\\",source=\\\"engine\\\"}[5m])`\n- `count_over_time({job=\\\"crowdsec\\\",source=\\\"nginx-bouncer\\\"} |= \\\"ban\\\" [5m])`\n- `sum by (status) (rate({job=\\\"nginx\\\"} | regexp \\\" (?P<status>[1-5][0-9]{2}) \\\" [5m]))`\n- `count_over_time({app=\\\"laravel\\\"} |= \\\"ERROR\\\" [5m])`"
            }
        }
    ]
}
