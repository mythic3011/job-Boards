APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=https://localhost
ASSET_URL=/
APP_SSL_PORT=443
APP_PORT=80
WWWUSER=1000
WWWGROUP=1000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# HTTP Response Logging
HTTP_LOGGING_ENABLED=true
HTTP_LOGGING_SUCCESS=true
HTTP_LOGGING_REDIRECTS=true
HTTP_LOGGING_SLOW_THRESHOLD=1000

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=laravel
DB_USERNAME=postgres
DB_PASSWORD=
# For local dev outside Docker, change DB_HOST to 127.0.0.1

# Installation bootstrap guard
# Local/testing defaults can leave the installer open; production-like environments should set one or more of:
# INSTALL_GUARD_ENABLED=true
# INSTALL_ALLOWED_IPS=127.0.0.1,203.0.113.10
# INSTALL_TOKEN=change-me

# Reverse proxy trust
# Trust only your direct front proxy by default.
TRUSTED_PROXIES=REMOTE_ADDR
# Supported values: x_forwarded, forwarded, aws_elb, traefik
TRUSTED_PROXY_HEADERS=x_forwarded

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_FROM_ADDRESS="noreply@localhost"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
# Set to your dev hostname when using a custom domain (e.g. OrbStack)
# VITE_HMR_HOST=laravel.test.jobs-boards.orb.local

# enable web ui for CrowdSec console and API
CROWDSEC_ENROLL_KEY=
CROWDSEC_DNS_PRIMARY=1.1.1.1
CROWDSEC_DNS_SECONDARY=8.8.8.8

MONITORING_PASSWORD=
MONITORING_PASSWORD_HASH=
SESSION_SECRET=
# client-side (Vite) variables are generated by bootstrap-env.sh in
# docker/auth-service/frontend/.env and prefixed with VITE_.
# they control the login page behaviour (auth endpoints, default redirect)
# plaintext source for Grafana admin bootstrap; runtime should consume GRAFANA_ADMIN_SECRET_FILE instead
GRAFANA_PASSWORD=
# optional explicit runtime file override for Grafana admin bootstrap
GRAFANA_ADMIN_SECRET_FILE=
# plaintext source for Prometheus basic auth bootstrap; runtime may consume PROMETHEUS_PASSWORD_HASH directly
PROMETHEUS_PASSWORD=
# final derived/runtime bcrypt hash for Prometheus basic auth
PROMETHEUS_PASSWORD_HASH=

# ── Auth Service (docker/auth-service) ──
# Username for admin login (default: admin)
MONITORING_ADMIN_USERNAME=
# Bcrypt hash of the admin password (required)
MONITORING_PASSWORD_HASH=
# Secret for session HMAC (required)
SESSION_SECRET=
# Shared HMAC secret used by auth-service when mirroring canonical audit events
CANONICAL_AUDIT_AUTH_SERVICE_SECRET=
# Port to run the auth service on (optional)
PORT=3000
